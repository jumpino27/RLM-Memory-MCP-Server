# RLM Memory MCP Server Configuration
# Copy this file to .env and fill in your values

# Required: Gemini API Key for AI-powered features
# Get one at: https://aistudio.google.com/

GEMINI_API_KEY="your-key-in-here"

# Optional: Default project path (defaults to current working directory)
# RLM_PROJECT_PATH=/path/to/your/project

# Optional: Transport mode (stdio or http)
TRANSPORT=stdio

# Optional: HTTP port (only used when TRANSPORT=http)
PORT=3847

# Optional: UI Server port
UI_PORT=3848

# Optional: Additional search paths for project discovery (path separator : on Unix, ; on Windows)
# RLM_SEARCH_PATHS=/path/to/projects:/another/path
